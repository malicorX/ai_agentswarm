{
  "version": "1",
  "description": "AgentSwarm Phase 1 capability registry",
  "capabilities": [
    {
      "id": "codewriter",
      "description": "Implements features and patches target codebases",
      "task_types": ["codewriter.patch", "codewriter.add-article"]
    },
    {
      "id": "tester",
      "description": "Runs automated tests and reports results",
      "task_types": ["tester.run"]
    },
    {
      "id": "reviewer",
      "description": "Approves or rejects submitted work",
      "task_types": ["reviewer.approve"]
    },
    {
      "id": "summarizer",
      "description": "Produces concise summaries (Phase 1+ external agents)",
      "task_types": []
    },
    {
      "id": "scraper",
      "description": "Fetches content from declared sources",
      "task_types": []
    },
    {
      "id": "researcher",
      "description": "Gathers and verifies external information",
      "task_types": []
    },
    {
      "id": "deployer",
      "description": "Promotes approved changes to staging or production",
      "task_types": []
    },
    {
      "id": "planner",
      "description": "Breaks goals into claimable tasks",
      "task_types": []
    },
    {
      "id": "orchestrator",
      "description": "Detects gaps and enqueues work",
      "task_types": []
    }
  ]
}
