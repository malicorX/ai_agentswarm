# Copy to /etc/agentswarm/platform.env on theebie.de (chmod 600, root-owned).
# Never commit the live file.

AGENTSWARM_DB=/var/lib/agentswarm/agentswarm.db
AGENTSWARM_PUBLIC_URL=https://theebie.de/agentswarm/api
AGENTSWARM_ASSIGNMENT_MODE=dispatch
AGENTSWARM_ASSIGNMENT_SECRET=change-me-long-random-dispatch-hmac-secret
# AGENTSWARM_ASSIGNMENT_LONG_POLL_MAX_SEC=60
# AGENTSWARM_MODEL_ALLOWLIST_ENFORCE=1
# AGENTSWARM_MODEL_ALLOWLIST_JSON=...  # optional full override
AGENTSWARM_SESSION_SECRET=change-me-long-random-session-secret
AGENTSWARM_BOOTSTRAP_TOKEN=change-me-maintainer-bootstrap

# Staging: open register for volunteer pilots (remove this line to enforce owner auth — P5.11)
AGENTSWARM_AUTH_DISABLED=1

# Phase 2 credibility ledger (P5.4 sign-off — see docs/infra/theebie/credibility-pilot-params.json)
AGENTSWARM_CREDIBILITY_ENABLED=1

# Major version bump: credibility haircut + probation (P5.7 / P5.9)
# AGENTSWARM_VERSION_MAJOR_HAIRCUT=0.5
# AGENTSWARM_VERSION_PROBATION_VERIFICATIONS=3
# AGENTSWARM_VERSION_REJECT_DOWNGRADES=1

# Credits auto-enabled in dispatch mode; override if needed:
# AGENTSWARM_CREDITS_ENABLED=1
# AGENTSWARM_CREDITS_INITIAL=100
# AGENTSWARM_CREDITS_GOAL_COST=50
# AGENTSWARM_CREDITS_REVIEWER_REWARD=15
# AGENTSWARM_CREDITS_PRICING_JSON={"creative.goal":{"post_cost":50}}
# See docs/infra/theebie/credits-pricing.json for a full table example.

# Git engineering: per-goal deploy keys minted at goal create when set to 1 (D1).
# AGENTSWARM_FORGE_MINT_KEYS=1
AGENTSWARM_PLATFORM_HOST=127.0.0.1
AGENTSWARM_PLATFORM_PORT=8010
