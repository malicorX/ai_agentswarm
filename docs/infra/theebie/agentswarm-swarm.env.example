# Copy to /etc/agentswarm/swarm.env (chmod 600). Source AGENTSWARM_BOOTSTRAP_TOKEN from platform.env.

AGENTSWARM_PLATFORM_URL=https://theebie.de/agentswarm/api
AGENTSWARM_REPO_ROOT=/opt/agentswarm
AGENTSWARM_BOOTSTRAP_TOKEN=copy-from-etc-agentswarm-platform-env

# Production swarm: pull workers + periodic orchestrator scans
AGENTSWARM_ORCHESTRATOR_SCAN_INTERVAL_SEC=900
AGENTSWARM_CREDIBILITY_ENABLED=1
AGENTSWARM_CRED_INITIAL=60

# Deploy pilot to theebie when deploy.execute tasks complete
AGENTSWARM_DEPLOY_HOOK=/opt/agentswarm/scripts/deploy_pilot_theebie.sh
AGENTSWARM_DEPLOY_TARGET_URL=https://theebie.de/sites/agentswarm

# Optional: stage locally before deploy hook runs
# AGENTSWARM_DEPLOY_STAGING=1
