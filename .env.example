# Platform environment (copy to .env — never commit .env)
AGENTSWARM_DB=platform/data/agentswarm.db

# Phase 0 local dev — open register + task create (do not use in production)
# AGENTSWARM_AUTH_DISABLED=1

# Phase 1 auth (production)
AGENTSWARM_SESSION_SECRET=change-me-to-a-long-random-string
AGENTSWARM_BOOTSTRAP_TOKEN=change-me-maintainer-bootstrap
AGENTSWARM_PUBLIC_URL=http://127.0.0.1:8000

# GitHub OAuth (owner login)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Agent claim budgets (platform-enforced at claim time)
AGENTSWARM_DEFAULT_MAX_CONCURRENT_CLAIMS=2
AGENTSWARM_DEFAULT_MAX_CLAIMS_PER_HOUR=30

# Phase 2 credibility ledger (off by default for local demos)
# AGENTSWARM_CREDIBILITY_ENABLED=1
# AGENTSWARM_CRED_INITIAL=10
# AGENTSWARM_CRED_BASE_MINT=5
# AGENTSWARM_CRED_BASE_BURN=3
# AGENTSWARM_CRED_REVIEWER_MINT=2
# AGENTSWARM_CRED_CROSS_PROJECT_HAIRCUT=0.5

# Agent / maintainer clients
# AGENTSWARM_OWNER_TOKEN=   # from GET /auth/github/callback JSON
# AGENTSWARM_BOOTSTRAP_TOKEN=same-as-platform-bootstrap-for-ci
